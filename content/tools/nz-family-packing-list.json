{
  "slug": "nz-family-packing-list",
  "title": "NZ Family Packing List Generator",
  "description": "Customised NZ packing lists by destination, season, and ages of your kids. Don't forget the sandfly repellent.",
  "icon": "🎒",
  "html_content": "<div class='tool-container'><h2 style='margin-top:0'>Build Your NZ Family Packing List</h2><div class='tool-row'><label>Season</label><select id='season' onchange='buildList()'><option value='summer'>Summer (Dec–Feb)</option><option value='autumn'>Autumn (Mar–May)</option><option value='winter'>Winter (Jun–Aug)</option><option value='spring'>Spring (Sep–Nov)</option></select></div><div class='tool-row'><label>Youngest child age</label><select id='youngest' onchange='buildList()'><option value='baby'>Under 2</option><option value='toddler'>2–4</option><option value='school'>5–10</option><option value='teen'>11+</option></select></div><div class='tool-row'><label>Destinations</label><select id='dest' onchange='buildList()'><option value='both'>Both islands</option><option value='north'>North Island only</option><option value='south'>South Island only</option><option value='west_coast'>West Coast / Glaciers</option><option value='beach'>Beach holiday (Bay of Islands)</option></select></div><div class='tool-row'><label>Transport</label><select id='transport' onchange='buildList()'><option value='campervan'>Campervan</option><option value='car'>Rental car + hotels</option><option value='fly'>Flying between cities</option></select></div><div id='packing-result'></div></div><script>const ALWAYS=['NZ power adaptors (Type I — same as Australia)','Reusable water bottles (save $20/day vs buying water)','Rain jackets for everyone (NZ weather is unpredictable)','Sunscreen SPF50+ (NZ UV is intense even on cloudy days)','First aid kit (plasters, antihistamine, paracetamol)','Travel insurance docs (digital + printed)','Passports / ID','NZ road map or offline maps (Google Maps offline NZ)','Snack bag for car trips (muesli bars, fruit, crackers)','Reusable bags for groceries'];const SUMMER=['Swimwear (2 pairs per person — things stay wet in a campervan)','Sun hats','Sunglasses','Light layers for evenings (Queenstown/Wanaka evenings cool even in summer)','Sandals/jandals','Beach towels (quick-dry)'];const WINTER=['Thermal base layers','Fleece or down jackets','Waterproof boots','Warm hats and gloves','Ski gear if skiing (or hire at resort)','Snow chains if driving South Island winter roads'];const AUTUMN=['Mid-layer fleece','Light waterproof jacket','Layers — mornings cool, afternoons warm'];const SPRING=['Rain jacket essential (spring = most changeable weather)','Layers','Light fleece'];const BABY=['Nappies (buy in bulk at Countdown/Pak'nSave)','Baby carrier/sling','Portable cot if holiday parks (most have cots — ask ahead)','Baby food or formula (all available at NZ supermarkets)','Changing mat','Baby sunscreen SPF50+'];const TODDLER=['Reins or wrist strap for busy areas','Snacks, snacks, snacks','Portable potty for road trips','Car seat (check with rental company — usually $10/day extra)','Small backpack with their \"own things\"'];const SCHOOL=['Activities for long drives (tablets with downloaded shows, headphones)','Their own camera or spare phone','A journal (helps them remember the trip)'];const TEEN=['Headphones','Power bank','Their phone with offline maps downloaded'];const CAMPERVAN_EXTRA=['Microfibre towels (quick-dry)','Sandfly repellent (DEET 30%+ — ESSENTIAL for West Coast)','Collapsible laundry basket','Clothes pegs','Small cutting board and kitchen knife','Coffee plunger','Levelling blocks','Outdoor chairs (not all vans include these)'];const WESTCOAST=['Sandfly repellent — bring MORE than you think','Waterproof everything — pack assume it will rain','Gumboots/wellies for kids'];function buildList(){const season=document.getElementById('season').value;const youngest=document.getElementById('youngest').value;const dest=document.getElementById('dest').value;const transport=document.getElementById('transport').value;let list=[...ALWAYS];if(season==='summer')list=[...list,...SUMMER];else if(season==='winter')list=[...list,...WINTER];else if(season==='autumn')list=[...list,...AUTUMN];else list=[...list,...SPRING];if(youngest==='baby')list=[...list,...BABY];else if(youngest==='toddler')list=[...list,...TODDLER];else if(youngest==='school')list=[...list,...SCHOOL];else list=[...list,...TEEN];if(transport==='campervan')list=[...list,...CAMPERVAN_EXTRA];if(dest==='west_coast'||dest==='south')list=[...list,...WESTCOAST];const div=document.getElementById('packing-result');div.innerHTML='<div class=\"tool-result\"><h3 style=\"margin-top:0\">Your Packing List ('+list.length+' items)</h3><ul style=\"columns:2;gap:2rem;list-style:none;padding:0\">'+list.map(i=>'<li style=\"margin-bottom:.5rem\">☐ '+i+'</li>').join('')+'</ul></div>';} buildList();</script>"
}
