{
  "slug": "nz-best-month-to-visit",
  "title": "Best Month to Visit NZ — Weather, Prices & Crowds by Month",
  "description": "Compare NZ weather, prices, and crowd levels for every month. Find the best time for your family holiday.",
  "icon": "🌤️",
  "html_content": "<div class='tool-container'><h2 style='margin-top:0'>NZ Month-by-Month Guide</h2><div class='tool-row'><label>Your destination</label><select id='dest_month' onchange='showMonth()'><option value='north'>North Island (Rotorua/Taupo)</option><option value='south' selected>South Island (Queenstown/Wanaka)</option><option value='beach'>Bay of Islands</option></select></div></div><div id='month-grid' style='display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;margin-top:1.5rem'></div><script>const MONTHS_NORTH=[{m:'January',weather:'Hot, 24°C avg',rain:'Low',crowds:'Peak (school hols)',price:'$$$',score:7,note:'Great weather but very busy. Book 3+ months ahead.'},{m:'February',weather:'Hot, 23°C avg',rain:'Low',crowds:'High',price:'$$$',score:8,note:'Best weather, school back. Slightly less busy than Jan.'},{m:'March',weather:'Warm, 20°C avg',rain:'Low',crowds:'Low',price:'$$',score:9,note:'Our top pick. Warm, quiet, affordable.'},{m:'April',weather:'Mild, 17°C avg',rain:'Low',crowds:'Low',price:'$$',score:8,note:'Autumn colours start. Fewer crowds.'},{m:'May',weather:'Mild, 14°C avg',rain:'Medium',crowds:'Very low',price:'$',score:6,note:'Getting cooler. Good budget option.'},{m:'June',weather:'Cool, 11°C avg',rain:'High',crowds:'Very low',price:'$',score:4,note:'Winter. Not ideal for outdoor activities.'},{m:'July',weather:'Cold, 9°C avg',rain:'High',crowds:'School hols',price:'$$',score:4,note:'NZ school holidays — expensive for a cold month.'},{m:'August',weather:'Cold, 10°C avg',rain:'High',crowds:'Low',price:'$',score:4,note:'Still winter. Some things closed.'},{m:'September',weather:'Mild, 13°C avg',rain:'Medium',crowds:'Low',price:'$$',score:7,note:'Spring. Activities opening up. Variable weather.'},{m:'October',weather:'Warm, 16°C avg',rain:'Medium',crowds:'Low',price:'$$',score:8,note:'Great shoulder month. Warming up.'},{m:'November',weather:'Warm, 19°C avg',rain:'Low',crowds:'Low',price:'$$',score:9,note:'Our #2 pick. Nearly summer, no crowds.'},{m:'December',weather:'Hot, 22°C avg',rain:'Low',crowds:'High',price:'$$$',score:7,note:'Peak season starts. Book early. Christmas period expensive.'}];const MONTHS_SOUTH=[{m:'January',weather:'Warm, 22°C avg',rain:'Low',crowds:'Peak',price:'$$$',score:7,note:'Best weather, but very busy and expensive.'},{m:'February',weather:'Warm, 21°C avg',rain:'Low',crowds:'High',price:'$$$',score:8,note:'Slightly quieter than Jan. Still great.'},{m:'March',weather:'Mild, 18°C avg',rain:'Low',crowds:'Low',price:'$$',score:9,note:'Best overall — warm, quiet, great value.'},{m:'April',weather:'Cool, 15°C avg',rain:'Low',crowds:'Very low',price:'$',score:8,note:'Autumn colours in Wanaka/Arrowtown. Magical.'},{m:'May',weather:'Cold, 11°C avg',rain:'Medium',crowds:'Very low',price:'$',score:5,note:'Shoulder season. Ski season starts late May.'},{m:'June',weather:'Cold, 7°C avg',rain:'Medium',crowds:'Ski season',price:'$$$',score:5,note:'Ski season peak. Expensive.'},{m:'July',weather:'Cold, 6°C avg',rain:'Medium',crowds:'Ski peak',price:'$$$',score:5,note:'Peak ski season. Not ideal for non-skiers.'},{m:'August',weather:'Cold, 8°C avg',rain:'Medium',crowds:'Ski season',price:'$$$',score:5,note:'End of ski season. Starting to warm.'},{m:'September',weather:'Mild, 12°C avg',rain:'Medium',crowds:'Low',price:'$$',score:7,note:'Spring. Some mountain roads still icy.'},{m:'October',weather:'Mild, 15°C avg',rain:'Low',crowds:'Low',price:'$$',score:8,note:'Great shoulder season. Warming fast.'},{m:'November',weather:'Warm, 18°C avg',rain:'Low',crowds:'Low',price:'$$',score:9,note:'Our #1 pick — everything open, no crowds.'},{m:'December',weather:'Warm, 21°C avg',rain:'Low',crowds:'High',price:'$$$',score:7,note:'Peak season. Book accommodation early.'}];const MONTHS_BEACH=[{m:'January',weather:'Hot, 26°C avg',rain:'Low',crowds:'Peak',price:'$$$',score:8,note:'Best beach weather. Very busy.'},{m:'February',weather:'Hot, 26°C avg',rain:'Low',crowds:'High',price:'$$$',score:9,note:'Hot and slightly quieter than Jan.'},{m:'March',weather:'Warm, 24°C avg',rain:'Low',crowds:'Low',price:'$$',score:9,note:'Top pick. Warm sea, fewer tourists.'},{m:'April',weather:'Warm, 21°C avg',rain:'Medium',crowds:'Low',price:'$$',score:7,note:'Still warm enough. Good value.'},{m:'May',weather:'Mild, 17°C avg',rain:'Medium',crowds:'Low',price:'$',score:5,note:'Getting cooler. Sea still swimmable just.'},{m:'June',weather:'Cool, 14°C avg',rain:'High',crowds:'Low',price:'$',score:3,note:'Too cold for beach holiday.'},{m:'July',weather:'Cool, 13°C avg',rain:'High',crowds:'Low',price:'$',score:3,note:'Off season.'},{m:'August',weather:'Cool, 13°C avg',rain:'High',crowds:'Low',price:'$',score:3,note:'Off season.'},{m:'September',weather:'Mild, 16°C avg',rain:'Medium',crowds:'Low',price:'$$',score:5,note:'Starting to warm. Variable.'},{m:'October',weather:'Warm, 19°C avg',rain:'Low',crowds:'Low',price:'$$',score:7,note:'Good month. Sea warming up.'},{m:'November',weather:'Warm, 22°C avg',rain:'Low',crowds:'Low',price:'$$',score:8,note:'Pre-season sweet spot.'},{m:'December',weather:'Hot, 24°C avg',rain:'Low',crowds:'High',price:'$$$',score:7,note:'Summer starts. Busy.'}];function getScore(s){if(s>=9)return'<span style=\"color:#16a34a;font-weight:700\">Excellent</span>';if(s>=7)return'<span style=\"color:#2563eb;font-weight:700\">Good</span>';if(s>=5)return'<span style=\"color:#d97706;font-weight:700\">OK</span>';return'<span style=\"color:#dc2626;font-weight:700\">Avoid</span>';}function showMonth(){const dest=document.getElementById('dest_month').value;const months=dest==='north'?MONTHS_NORTH:dest==='beach'?MONTHS_BEACH:MONTHS_SOUTH;const div=document.getElementById('month-grid');div.innerHTML=months.map(m=>`<div style=\"border:1px solid #e5e7eb;border-radius:8px;padding:1rem;background:${m.score>=9?'#f0fdf4':m.score>=7?'#f0f4ff':m.score>=5?'#fffbeb':'#fef2f2'}\"><strong>${m.m}</strong><br><span style=\"font-size:.85rem;color:#6b7280\">${m.weather} · Rain: ${m.rain}</span><br><span style=\"font-size:.85rem\">Crowds: ${m.crowds}</span><br><span style=\"font-size:.85rem\">Price: ${m.price}</span><br>${getScore(m.score)}<br><span style=\"font-size:.82rem;color:#6b7280;margin-top:.4rem;display:block\">${m.note}</span></div>`).join('');} showMonth();</script>",
