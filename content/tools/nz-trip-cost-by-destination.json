{
  "slug": "nz-trip-cost-by-destination",
  "title": "NZ Trip Cost Estimator — By Destination & Stay Length",
  "description": "See real cost breakdowns for family trips to specific NZ destinations — Queenstown, Rotorua, Bay of Islands, and more. Includes accommodation, activities, food, and fuel.",
  "icon": "🧮",
  "html_content": "<style>.dest-sel-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.6rem;margin-bottom:1.5rem}.dest-btn{padding:.6rem .8rem;border:2px solid #e5e7eb;border-radius:8px;background:#fff;cursor:pointer;font-size:.85rem;font-weight:600;text-align:center;transition:all .15s}.dest-btn.active{border-color:#0369a1;background:#e0f2fe;color:#0369a1}.cost-breakdown{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1rem 0}.cost-item{background:#f9fafb;border-radius:8px;padding:1rem;border:1px solid #e5e7eb}.cost-item .ci-val{font-size:1.4rem;font-weight:800;color:#0369a1}.cost-item .ci-label{font-size:.78rem;color:#6b7280;margin-top:.1rem}.cost-total{background:#1f2937;color:#fff;border-radius:10px;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;margin-top:1rem}.cost-total .ct-val{font-size:2rem;font-weight:900}.savings-box{background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:.85rem 1rem;margin-top:1rem;font-size:.88rem}.savings-box strong{color:#15803d}.activity-list{margin-top:1.25rem;padding-left:0;list-style:none}.activity-list li{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid #f3f4f6;font-size:.88rem}.activity-list li:last-child{border:none}.act-price{font-weight:700;color:#0369a1}</style><div class='tool-container'><h2 style='margin-top:0'>NZ Trip Cost by Destination</h2><div class='tool-row'><label>Nights in this destination</label><input type='number' id='nights' value='3' min='1' max='14' onchange='calcDest()'></div><div class='tool-row'><label>Adults</label><input type='number' id='dadults' value='2' min='1' max='4' onchange='calcDest()'><label style='margin-left:1rem'>Children</label><input type='number' id='dchildren' value='2' min='0' max='4' onchange='calcDest()'></div><div class='tool-row'><label>Accommodation</label><select id='daccom' onchange='calcDest()'><option value='van'>Campervan + holiday park ($200/night total)</option><option value='motel' selected>Holiday park cabin / motel ($180/night)</option><option value='hotel'>Hotel ($300/night)</option></select></div><p style='font-size:.88rem;color:#6b7280;margin-bottom:1rem'>Select a destination:</p><div class='dest-sel-grid' id='dest-btns'></div><div id='dest-result'><div style='text-align:center;padding:2rem;color:#9ca3af'><p>Select a destination above to see estimated costs.</p></div></div></div><script>const DESTS={queenstown:{name:'Queenstown',emoji:'🏔️',slug:'queenstown-with-kids',accomMult:1.4,fuelKm:180,activities:[{name:'Skyline Luge (4 rides)',adult:75,child:60},{name:'Shotover Jet',adult:149,child:99},{name:'Queenstown gondola',adult:39,child:19},{name:'Nevis Bungy (adults)',adult:275,child:0},{name:'Lake Wakatipu cruise',adult:45,child:25},{name:'TSS Earnslaw steamship',adult:79,child:39}],mustDo:['Skyline Luge','Shotover Jet'],savings:'Buying a Queenstown activity combo saves 15–20%. Book via Bookme for discounts.'},rotorua:{name:'Rotorua',emoji:'♨️',slug:'rotorua-family-guide',accomMult:0.95,fuelKm:80,activities:[{name:'Wai-O-Tapu',adult:47,child:16},{name:'Te Puia',adult:79,child:40},{name:'Agrodome farm show',adult:45,child:25},{name:'Skyline Luge Rotorua',adult:55,child:45},{name:'OGO Zorbing',adult:55,child:45},{name:'Polynesian Spa family',adult:35,child:20}],mustDo:['Wai-O-Tapu','Te Puia'],savings:'The Rotorua i-SITE pass can save families 20%+ on combined attractions. Book via Bookme.'},taupo:{name:'Taupo',emoji:'💧',slug:'taupo-with-kids',accomMult:0.9,fuelKm:60,activities:[{name:'Huka Falls (free)',adult:0,child:0},{name:'Huka Jet boat',adult:149,child:99},{name:'Tongariro Alpine Crossing',adult:65,child:35},{name:'Lake Taupo cruise',adult:55,child:25},{name:'AC Baths thermal pool',adult:22,child:15},{name:'Craters of the Moon (DOC)',adult:10,child:6}],mustDo:['Huka Falls','Huka Jet'],savings:'Huka Falls is free and unmissable. Several Taupo activities have significant Bookme discounts.'},'bay-of-islands':{name:'Bay of Islands',emoji:'🐬',slug:'bay-of-islands-family',accomMult:1.05,fuelKm:100,activities:[{name:'Waitangi Treaty Grounds',adult:40,child:0},{name:'Fullers dolphin cruise',adult:129,child:65},{name:'Paihia-Russell ferry',adult:8,child:5},{name:'Cape Reinga trip',adult:99,child:70},{name:'Hole in the Rock cruise',adult:139,child:75},{name:'Kerikeri Mission House',adult:12,child:6}],mustDo:['Waitangi Treaty Grounds','Dolphin cruise'],savings:'Book the dolphin/Hole in the Rock combo for best value. Kids under 5 often free.'},christchurch:{name:'Christchurch',emoji:'🐧',slug:'christchurch-with-kids',accomMult:0.9,fuelKm:120,activities:[{name:'Antarctic Centre + penguins',adult:75,child:40},{name:'Christchurch gondola',adult:32,child:16},{name:'Willowbank Wildlife Reserve',adult:38,child:20},{name:'Orana Wildlife Park',adult:38,child:22},{name:'Botanic Gardens (free)',adult:0,child:0},{name:'Punt on the Avon',adult:30,child:20}],mustDo:['Antarctic Centre','Botanic Gardens'],savings:'The Antarctic Centre is the standout paid attraction — worth full price. Botanic Gardens and city walks are free.'},nelson:{name:'Nelson / Abel Tasman',emoji:'🏖️',slug:'nelson-abel-tasman-family',accomMult:0.95,fuelKm:90,activities:[{name:'Abel Tasman water taxi',adult:75,child:50},{name:'Sea kayak hire (half day)',adult:85,child:65},{name:'Nelson Saturday market',adult:0,child:0},{name:'Motueka River swim (free)',adult:0,child:0},{name:'Kaiteriteri beach',adult:0,child:0},{name:'Whale watching Kaikoura',adult:165,child:85}],mustDo:['Abel Tasman water taxi','Kaiteriteri beach'],savings:'Abel Tasman beach access is free — pay for water taxi if you want remote beaches. Most beaches are free.'},wellington:{name:'Wellington',emoji:'🏛️',slug:'wellington-with-kids',accomMult:1.1,fuelKm:50,activities:[{name:'Te Papa Museum (free)',adult:0,child:0},{name:'Wellington cable car',adult:13,child:7},{name:'Zealandia wildlife sanctuary',adult:55,child:25},{name:'Weta Workshop tour',adult:37,child:22},{name:'Karori Wildlife Sanctuary',adult:55,child:25},{name:'Wellington Zoo',adult:32,child:18}],mustDo:['Te Papa','Cable car'],savings:'Te Papa is free and world-class — spend 3–4 hours there. Wellington is NZ's best value city.'},wanaka:{name:'Wanaka',emoji:'🏔️',slug:'wanaka-with-kids',accomMult:1.15,fuelKm:90,activities:[{name:'Puzzling World',adult:25,child:19},{name:'Roy's Peak hike (free)',adult:0,child:0},{name:'Lake Wanaka swimming (free)',adult:0,child:0},{name:'Wanaka Tree photo walk (free)',adult:0,child:0},{name:'Treble Cone ski day (winter)',adult:185,child:95},{name:'Wildwire Wanaka climbing',adult:149,child:99}],mustDo:['Puzzling World','Lake Wanaka'],savings:'Wanaka has more free activities than almost any NZ destination — lake, parks, and hikes are all free.'},coromandel:{name:'Coromandel',emoji:'🌊',slug:'coromandel-with-kids',accomMult:0.9,fuelKm:100,activities:[{name:'Hot Water Beach spade hire',adult:5,child:5},{name:'Cathedral Cove walk (free)',adult:0,child:0},{name:'Driving Creek Railway',adult:40,child:22},{name:'Coromandel Town goldmine',adult:28,child:18},{name:'Hahei beach (free)',adult:0,child:0},{name:'Coromandel Oyster Company',adult:25,child:10}],mustDo:['Hot Water Beach','Cathedral Cove'],savings:'Hot Water Beach and Cathedral Cove are the must-dos and both nearly free. The Coromandel is NZ's best-value beach destination.'},fiordland:{name:'Fiordland / Milford',emoji:'🏔️',slug:'fiordland-milford-sound-family',accomMult:1.2,fuelKm:200,activities:[{name:'Milford Sound cruise (standard)',adult:89,child:30},{name:'Milford Sound kayak',adult:185,child:95},{name:'Te Anau glowworm caves',adult:89,child:30},{name:'Kepler Track day walk (free)',adult:0,child:0},{name:'Fiordland Cinema (Ata Whenua)',adult:18,child:12},{name:'Milford Track guided walk',adult:2650,child:1500}],mustDo:['Milford Sound cruise','Glowworm caves'],savings:'Book the Milford cruise well ahead in summer — popular departures sell out. Early morning cruises have fewer tour buses.'}};const ACCOM={van:200,motel:180,hotel:300};function init(){const grid=document.getElementById('dest-btns');Object.entries(DESTS).forEach(([k,d])=>{const b=document.createElement('button');b.className='dest-btn';b.textContent=d.emoji+' '+d.name;b.onclick=()=>{document.querySelectorAll('.dest-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');window._selDest=k;calcDest()};grid.appendChild(b)});}function calcDest(){const k=window._selDest;if(!k)return;const d=DESTS[k];const nights=+document.getElementById('nights').value||3;const adults=+document.getElementById('dadults').value||2;const children=+document.getElementById('dchildren').value||2;const pax=adults+children;const accomKey=document.getElementById('daccom').value;const accomPerNight=Math.round(ACCOM[accomKey]*d.accomMult);const accomTotal=accomPerNight*nights;const fuelTotal=Math.round(d.fuelKm*0.22);const foodPerDay=Math.round((accomKey==='van'?55:90)*pax);const foodTotal=foodPerDay*nights;const actRows=d.activities.map(a=>{const total=(a.adult*adults)+(a.child*children);return`<li><span>${a.name}${d.mustDo.includes(a.name)?' ⭐':''}</span><span class='act-price'>${total===0?'Free':'$'+total}</span></li>`}).join('');const recActs=d.activities.filter(a=>d.mustDo.includes(a.name));const actTotal=Math.round(recActs.reduce((s,a)=>(s+(a.adult*adults)+(a.child*children)),0)*nights/3);const total=accomTotal+fuelTotal+foodTotal+actTotal;document.getElementById('dest-result').innerHTML=`<h3 style='margin:.5rem 0'>${d.emoji} ${d.name} — ${nights} night${nights!==1?'s':''} for ${pax} people</h3><div class='cost-breakdown'><div class='cost-item'><div class='ci-val'>$${accomTotal.toLocaleString()}</div><div class='ci-label'>Accommodation (${nights} nights @ $${accomPerNight}/night)</div></div><div class='cost-item'><div class='ci-val'>$${actTotal.toLocaleString()}</div><div class='ci-label'>Recommended activities (⭐ must-dos)</div></div><div class='cost-item'><div class='ci-val'>$${foodTotal.toLocaleString()}</div><div class='ci-label'>Food & groceries</div></div><div class='cost-item'><div class='ci-val'>$${fuelTotal.toLocaleString()}</div><div class='ci-label'>Fuel to/from (~${d.fuelKm}km round trip)</div></div></div><div class='cost-total'><span>Estimated total (${nights} nights)</span><span class='ct-val'>$${total.toLocaleString()}</span></div><div class='savings-box'><strong>💡 Savings tip:</strong> ${d.savings}</div><h4 style='margin:1.25rem 0 .5rem'>All activities with prices (family of ${pax}):</h4><ul class='activity-list'>${actRows}</ul><p style='font-size:.8rem;color:#9ca3af;margin-top:1rem'>⭐ = recommended must-do. Prices are approximate 2026 estimates. Book via Bookme for up to 40% discount on many activities. <a href='/destinations/${d.slug}/'>Full ${d.name} destination guide →</a></p>`;}init();</script>"
}
